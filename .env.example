# Copy this file to .env and adjust as needed before running
# `docker compose up --build`. These values are for LOCAL DEMO USE ONLY.

# --- PostgreSQL ---
POSTGRES_DB=opscontrolplane
POSTGRES_USER=ops_user
POSTGRES_PASSWORD=ops_password

# --- Backend / JWT ---
JWT_SECRET=change-me-in-production-super-secret-key

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=admin

# --- Frontend build-time API URL ---
VITE_API_URL=http://localhost:8080/api
