# -----------------------------------------------------------------------
# TEMPLATE ONLY - DO NOT APPLY AS-IS AND DO NOT COMMIT REAL SECRETS.
#
# This file demonstrates the shape of the Secret the backend Deployment
# expects (see k8s/backend-deployment.yaml envFrom). The placeholder
# values below are NOT valid credentials.
#
# For real usage, prefer one of:
#   kubectl create secret generic ops-control-plane-secret \
#     --namespace ops-control-plane \
#     --from-literal=DB_USER=ops_user \
#     --from-literal=DB_PASSWORD='<real-password>' \
#     --from-literal=JWT_SECRET='<real-jwt-secret>'
#
# or an external secret manager (HashiCorp Vault, AWS Secrets Manager,
# Sealed Secrets, External Secrets Operator, etc.) integrated with your
# cluster. Never store production secrets in plain YAML in git.
# -----------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: ops-control-plane-secret
  namespace: ops-control-plane
type: Opaque
stringData:
  # DB_USER / DB_PASSWORD match the property names read by
  # backend/src/main/resources/application.yml
  DB_USER: "ops_user"
  DB_PASSWORD: "REPLACE_ME"
  JWT_SECRET: "REPLACE_ME_WITH_A_LONG_RANDOM_SECRET"
  POSTGRES_USER: "ops_user"
  POSTGRES_PASSWORD: "REPLACE_ME"
